        "graphql": "^16.13.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.0",
        "react-hot-toast": "^2.6.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "6",
        "react-syntax-highlighter": "15.6.1",
        "recharts": "^3.8.0",
